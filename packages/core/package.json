{
  "name": "@vocion/core",
  "version": "0.1.0",
  "private": true,
  "description": "Vocion — Next.js app, Postgres schema, MCP server, workflow runner.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:spotlight": "npx @spotlightjs/spotlight",
    "dev:next": "next dev",
    "dev": "run-p db-server:file dev:*",
    "build:next": "next build --webpack",
    "build-local": "run-p db-server:memory build:next --race",
    "build": "run-s db:migrate build:next",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:types": "tsc --noEmit --pretty",
    "check:i18n": "i18n-check -l src/locales -s en -u src -f next-intl",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db-server:file": "pglite-server --db=local.db --run 'npm run db:migrate'",
    "db-server:memory": "pglite-server --run 'npm run db:migrate'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -c -- drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "context:apply": "dotenv -c -- tsx src/scripts/apply-context.ts",
    "context:check": "dotenv -c -- tsx src/scripts/apply-context.ts --dry-run",
    "context:export": "dotenv -c -- tsx src/scripts/export-context.ts",
    "mcp:serve": "dotenv -c -- tsx src/interfaces/mcp/bin.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.mts",
    "build-storybook": "storybook build",
    "stripe:listen": "stripe listen --forward-to localhost:3000/webhook/billing",
    "stripe:setup-price": "dotenv -c production -- tsx ./scripts/createStripePrice.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@clerk/localizations": "^3.37.5",
    "@clerk/nextjs": "^6.39.3",
    "@clerk/themes": "^2.4.57",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@hookform/resolvers": "^5.2.2",
    "@logtape/logtape": "^2.0.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@orpc/client": "^1.14.0",
    "@orpc/server": "^1.14.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.51.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-table": "^8.21.3",
    "@uiw/react-codemirror": "^4.25.9",
    "@vocion/sdk": "*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "langfuse": "^3.38.20",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "openai": "^6.35.0",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^18.5.0",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.8.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@chromatic-com/playwright": "^0.13.2",
    "@clerk/testing": "^1.14.6",
    "@electric-sql/pglite": "^0.4.5",
    "@electric-sql/pglite-socket": "^0.1.5",
    "@faker-js/faker": "^10.4.0",
    "@lingual/i18n-check": "^0.9.4",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@spotlightjs/spotlight": "^4.11.3",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/nextjs-vite": "^10.3.6",
    "@swc/helpers": "^0.5.21",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "checkly": "^7.12.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.13",
    "postcss-load-config": "^6.0.1",
    "rimraf": "^6.1.3",
    "storybook": "^10.2.15",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.2.0"
  }
}
