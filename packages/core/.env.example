# ==============================================================================
# Vocion - Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Clerk Authentication (https://clerk.com)
# Create a Clerk application at https://dashboard.clerk.com
# Enable "Organizations" in Clerk Dashboard > Organization management > Settings
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# Local: use docker-compose.yml → docker compose up -d
# Production: Neon (neon.tech), Supabase, AWS RDS, etc.
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/vocion

# ------------------------------------------------------------------------------
# Stripe Payments (https://stripe.com)
# Create a Stripe account at https://dashboard.stripe.com
# Get keys from Developers > API Keys
# Webhook secret from Developers > Webhooks (or `npm run stripe:listen`)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Billing plan environment: dev | test | prod
# Use "dev" for development, "prod" for production Stripe price IDs
BILLING_PLAN_ENV=dev

# ------------------------------------------------------------------------------
# Sentry Error Monitoring (https://sentry.io) [OPTIONAL]
# Create a Sentry project at https://sentry.io
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://your_dsn@sentry.io/project_id
# SENTRY_AUTH_TOKEN=sntrys_your_sentry_auth_token
# SENTRY_ORGANIZATION=your_org
# SENTRY_PROJECT=vocion

# To disable Sentry in development:
# NEXT_PUBLIC_SENTRY_DISABLED=true

# ------------------------------------------------------------------------------
# Better Stack Logging (https://betterstack.com) [OPTIONAL]
# Create a source at Better Stack > Logs > Sources
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN=your_better_stack_source_token
# NEXT_PUBLIC_BETTER_STACK_INGESTING_HOST=in.logs.betterstack.com

# ------------------------------------------------------------------------------
# Checkly Monitoring (https://www.checklyhq.com) [OPTIONAL]
# Used for production monitoring-as-code
# ------------------------------------------------------------------------------
# CHECKLY_EMAIL_ADDRESS=your_email@example.com
# CHECKLY_PROJECT_NAME=Vocion
# CHECKLY_LOGICAL_ID=vocion

# ------------------------------------------------------------------------------
# Retrieval (native pgvector — L.6 removed the Onyx dependency)
# Embeddings flow through OpenAI by default; override with VOCION_EMBEDDING_MODEL.
# ------------------------------------------------------------------------------
# VOCION_EMBEDDING_MODEL=text-embedding-3-small

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LOGGING_LEVEL=debug
NEXT_TELEMETRY_DISABLED=1

# ------------------------------------------------------------------------------
# Built-in agent tools (web search · browse · image · code · artifacts)
# Pluggable providers, each with a keyless/low-cost default. Tools degrade
# gracefully when a provider's key is missing.
# ------------------------------------------------------------------------------
# Web search — default tavily (needs TAVILY_API_KEY). Alt: brave (BRAVE_API_KEY).
# VOCION_WEBSEARCH_PROVIDER=tavily
# TAVILY_API_KEY=
# BRAVE_API_KEY=
#
# Browse (fetch + crawl) — default builtin (no key). Opt-in: firecrawl for
# JS-heavy pages (needs FIRECRAWL_API_KEY).
# VOCION_BROWSE_PROVIDER=builtin
# FIRECRAWL_API_KEY=
#
# Image generation — default openai gpt-image-1 (reuses OPENAI_API_KEY).
# VOCION_IMAGE_PROVIDER=openai
# VOCION_IMAGE_MODEL=gpt-image-1
#
# Code/calc — default builtin safe calculator (no key). Opt-in: e2b sandbox
# for full code execution (needs E2B_API_KEY).
# VOCION_CODE_PROVIDER=builtin
# E2B_API_KEY=
#
# Artifacts (generated images, CSVs, charts, docs) are written here and served
# at /artifacts. Point at a mounted volume / object store for production.
# VOCION_ARTIFACTS_DIR=
# VOCION_ARTIFACTS_URL_BASE=/artifacts
