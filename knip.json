{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["docker-compose.yml", "infra/**/*.{yml,yaml,sh,tf}"],
      "ignore": ["infra/terraform/**"],
      "ignoreDependencies": ["conventional-changelog-conventionalcommits", "@commitlint/types"]
    },
    "packages/core": {
      "entry": [
        "src/app/**/{page,layout,route,loading,error,not-found,sitemap,robots,opengraph-image,twitter-image,icon,apple-icon}.{ts,tsx}",
        "src/middleware.ts",
        "src/instrumentation*.ts",
        "src/scripts/*.ts",
        "src/interfaces/mcp/bin.ts",
        "src/{global,sentry.client,sentry.server,sentry.edge}.ts",
        "tests/**/*.{ts,tsx}",
        ".storybook/**/*.{ts,tsx}",
        "next.config.ts",
        "drizzle.config.ts",
        "vitest.config.mts",
        "playwright.config.ts",
        "checkly.config.ts",
        "postcss.config.mjs"
      ],
      "project": ["src/**/*.{ts,tsx}", "!src/**/*.test.{ts,tsx}"],
      "ignore": [
        "src/components/ui/**",
        "src/features/dashboard/chat/**",
        "src/features/auth/ProtectFallback.tsx",
        "src/templates/**",
        "src/types/**",
        "src/libs/plugins/**",
        "src/libs/onyx/**",
        "src/libs/retrieval/**",
        "src/libs/llm/**",
        "src/libs/temporal/**",
        "src/libs/Langfuse/**",
        "src/libs/crypto/**",
        "src/libs/docs/**",
        "src/libs/I18n.ts",
        "src/libs/agentAccent.ts",
        "src/libs/Langfuse.ts",
        "src/services/**",
        "src/routers/**"
      ],
      "ignoreDependencies": [
        "@radix-ui/react-accordion",
        "@radix-ui/react-label",
        "@tanstack/react-table",
        "radix-ui",
        "react-hook-form",
        "@swc/helpers",
        "@tailwindcss/typography",
        "tailwindcss",
        "tw-animate-css",
        "@clerk/types",
        "@clerk/nextjs",
        "vite"
      ],
      "includeEntryExports": false
    },
    "packages/sdk": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["react"]
    },
    "packages/plugins/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreBinaries": ["dotenv", "tofu", "tsx", "playwright", "production", "checkly", "stripe"],
  "rules": {
    "exports": "off",
    "types": "off",
    "duplicates": "off"
  }
}
