# Vocion .env.production — single-EC2 deploy (Phase F).
#
# Copy to .env.production on the EC2, fill in every (set me) value.
# Never commit. Operator-managed; the bootstrap script reads from this
# path. The Dockerfile does not bake any secrets; everything below is
# injected at container start.

# ----- DNS -----
VOCION_HOSTNAME=app.vocion.ai          # (set me) — Caddy provisions TLS for this hostname
# Public base URL — used by sitemap.xml, robots.txt, and any
# server-rendered absolute link. MUST include the scheme.
NEXT_PUBLIC_APP_URL=https://app.vocion.ai

# ----- Database -----
# Default routes to the in-network postgres service started by the
# repo-root docker-compose.yml. Replace with your RDS endpoint to
# split DB onto a managed service.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/vocion

# ----- Clerk (auth) -----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_   # (set me)
CLERK_SECRET_KEY=sk_live_                    # (set me)

# ----- LLM providers -----
ANTHROPIC_API_KEY=sk-ant-                    # (set me)
OPENAI_API_KEY=sk-                           # (set me — only if any agent uses OpenAI)

# Optional per-role model overrides. Defaults:
#   main       = claude-sonnet-4-6
#   classifier = claude-haiku-4-5-20251001
# VOCION_LLM_MODEL_MAIN=claude-opus-4-7
# VOCION_LLM_PROVIDER=anthropic

# Opt into the deepagents runtime via the new /rpc/agent/stream route.
VOCION_AGENT_RUNTIME=deepagents

# ----- Retrieval -----
# Native pgvector retrieval (no external dependency). The app's
# Postgres has the pgvector extension installed (see L.1). To opt out
# of the rerank pass or override the embedding model, set:
# VOCION_EMBEDDING_MODEL=text-embedding-3-small
# VOCION_RERANK_MODEL=claude-haiku-4-5-20251001

# ----- Langfuse (observability) -----
LANGFUSE_BASE_URL=https://cloud.langfuse.com  # or http://langfuse-web:3000 for self-hosted
LANGFUSE_PUBLIC_KEY=pk-lf-                    # (set me)
LANGFUSE_SECRET_KEY=sk-lf-                    # (set me)
LANGFUSE_PROJECT_ID=demo                      # used for /dashboard/observability deep-links
# Public mirrors for the in-app "Open in Langfuse" buttons. Use the
# externally-reachable Langfuse URL (the one a browser can hit), not the
# in-VPC one.
NEXT_PUBLIC_LANGFUSE_BASE_URL=https://langfuse.your-domain.com
NEXT_PUBLIC_LANGFUSE_PROJECT_ID=demo

# ----- Feedback worker (opt-in) -----
# Set to 1 to start the worker container. Anti-loop filter — leave
# blank if you have no bot identity yet.
ENABLE_FEEDBACK_WORKER=1
VOCION_BOT_EMAIL=

# ----- Sentry (optional) -----
# Leave NEXT_PUBLIC_SENTRY_DISABLED=1 to skip Sentry source-map upload.
NEXT_PUBLIC_SENTRY_DISABLED=1
# SENTRY_DSN=
# SENTRY_ORGANIZATION=
# SENTRY_PROJECT=

# ----- Stripe (optional) -----
# Leave unset to disable billing flows.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
