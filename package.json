{
  "name": "compiles",
  "version": "0.0.0",
  "private": true,
  "description": "Compiles — monorepo root. See packages/core for the framework, packages/sdk for the plugin contract, packages/plugins/* for shipped plugins.",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/core",
    "packages/sdk",
    "packages/plugins/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @compiles/core",
    "dev:next": "npm run dev:next --workspace @compiles/core",
    "dev:up": "docker compose up -d && npm run dev:onyx:up",
    "dev:down": "docker compose down && npm run dev:onyx:down",
    "dev:status": "docker compose ps && echo '--- onyx ---' && (cd infra/onyx/onyx-repo/deployment/docker_compose && docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.override.yml -p onyx-stack ps)",
    "dev:onyx:up": "if [ ! -d infra/onyx/onyx-repo ]; then echo '→ first run — cloning Onyx via setup.sh' && bash infra/onyx/setup.sh; fi && cd infra/onyx/onyx-repo/deployment/docker_compose && docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.override.yml -p onyx-stack up -d",
    "dev:onyx:down": "cd infra/onyx/onyx-repo/deployment/docker_compose && docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.override.yml -p onyx-stack down",
    "build": "npm run build --workspace @compiles/core",
    "start": "npm run start --workspace @compiles/core",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:types": "npm run check:types --workspace @compiles/core",
    "check:deps": "knip",
    "check:i18n": "npm run check:i18n --workspace @compiles/core",
    "test": "npm run test --workspace @compiles/core",
    "test:e2e": "npm run test:e2e --workspace @compiles/core",
    "db:generate": "npm run db:generate --workspace @compiles/core",
    "db:migrate": "npm run db:migrate --workspace @compiles/core",
    "db:studio": "npm run db:studio --workspace @compiles/core",
    "context:apply": "npm run context:apply --workspace @compiles/core",
    "context:check": "npm run context:check --workspace @compiles/core",
    "context:export": "npm run context:export --workspace @compiles/core",
    "mcp:serve": "npm run mcp:serve --workspace @compiles/core",
    "storybook": "npm run storybook --workspace @compiles/core",
    "storybook:test": "npm run storybook:test --workspace @compiles/core",
    "build-storybook": "npm run build-storybook --workspace @compiles/core",
    "stripe:listen": "npm run stripe:listen --workspace @compiles/core",
    "stripe:setup-price": "npm run stripe:setup-price --workspace @compiles/core",
    "commit": "commit"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@commitlint/prompt-cli": "^20.4.3",
    "@eslint-react/eslint-plugin": "~2.5.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^9.39.2",
    "eslint-plugin-format": "^1.2.0",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-storybook": "^10.2.15",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "knip": "^5.85.0",
    "lefthook": "^2.1.2",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  }
}
