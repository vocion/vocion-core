# ==============================================================================
# CoreContext - Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Clerk Authentication (https://clerk.com)
# Create a Clerk application at https://dashboard.clerk.com
# Enable "Organizations" in Clerk Dashboard > Organization management > Settings
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# Local: use docker-compose.yml → docker compose up -d
# Production: Neon (neon.tech), Supabase, AWS RDS, etc.
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/corecontext

# ------------------------------------------------------------------------------
# Stripe Payments (https://stripe.com)
# Create a Stripe account at https://dashboard.stripe.com
# Get keys from Developers > API Keys
# Webhook secret from Developers > Webhooks (or `npm run stripe:listen`)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Billing plan environment: dev | test | prod
# Use "dev" for development, "prod" for production Stripe price IDs
BILLING_PLAN_ENV=dev

# ------------------------------------------------------------------------------
# Sentry Error Monitoring (https://sentry.io) [OPTIONAL]
# Create a Sentry project at https://sentry.io
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://your_dsn@sentry.io/project_id
# SENTRY_AUTH_TOKEN=sntrys_your_sentry_auth_token
# SENTRY_ORGANIZATION=your_org
# SENTRY_PROJECT=corecontext

# To disable Sentry in development:
# NEXT_PUBLIC_SENTRY_DISABLED=true

# ------------------------------------------------------------------------------
# Better Stack Logging (https://betterstack.com) [OPTIONAL]
# Create a source at Better Stack > Logs > Sources
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN=your_better_stack_source_token
# NEXT_PUBLIC_BETTER_STACK_INGESTING_HOST=in.logs.betterstack.com

# ------------------------------------------------------------------------------
# Checkly Monitoring (https://www.checklyhq.com) [OPTIONAL]
# Used for production monitoring-as-code
# ------------------------------------------------------------------------------
# CHECKLY_EMAIL_ADDRESS=your_email@example.com
# CHECKLY_PROJECT_NAME=CoreContext
# CHECKLY_LOGICAL_ID=corecontext

# ------------------------------------------------------------------------------
# Onyx Context Engine (https://docs.onyx.app)
# Self-hosted: run `./infra/onyx/setup.sh` then start with Docker Compose
# API key: create in Onyx Admin > API Keys
# ------------------------------------------------------------------------------
ONYX_API_URL=http://localhost:8080
ONYX_API_KEY=your_onyx_api_key

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LOGGING_LEVEL=debug
NEXT_TELEMETRY_DISABLED=1
